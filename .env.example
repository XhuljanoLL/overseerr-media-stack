# Copy this file to .env and adjust values for your machine.
# These values are used by docker compose for environment interpolation.

# Common container settings
PUID=1000
PGID=1000
TZ=Europe/Tirana

# Optional port overrides
PULSARR_PORT=3003
JELLYFIN_HTTP_PORT=8096
JELLYFIN_DISCOVERY_PORT=7359
PROWLARR_PORT=9696
SONARR_PORT=8989
RADARR_PORT=7878
FLARESOLVERR_PORT=8191
QBITTORRENT_PORT=8088
QBITTORRENT_WEBUI_PORT=8080
TDARR_WEBUI_PORT=8265
TDARR_SERVER_PORT=8266
TDARR_NODE_PORT=8267

# TDarr options
TDARR_UMASK_SET=002
TDARR_INTERNAL_NODE=true
TDARR_NODE_ID=tdarr
TDARR_NODE_NAME=Node-1
TDARR_SERVER_IP=0.0.0.0
TDARR_NODE_IP=0.0.0.0
TDARR_GPU=false
TDARR_NVIDIA_VISIBLE_DEVICES=all
TDARR_NVIDIA_DRIVER_CAPABILITIES=compute,utility

# FlareSolverr options
LOG_LEVEL=info
LOG_HTML=false
CAPTCHA_SOLVER=none
